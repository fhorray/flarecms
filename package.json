    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "happy-dom": "^20.8.9",
    "picocolors": "^1.1.1",
    "turbo": "^2.9.5",
    "wrangler": "^4.81.0"
