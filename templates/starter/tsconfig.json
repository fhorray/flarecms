{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["./src/*"]
    },
  },
  "include": ["src/**/*", "worker-configuration.d.ts"]
}
