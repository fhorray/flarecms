{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "playground",
  "main": "src/index.ts",
  "compatibility_date": "2024-04-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {}
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "playground-db",
      "database_id": "replace-me"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "replace-me"
    }
  ],
  "worker_loaders": [
    {
      "binding": "LOADER",
    }
  ]
}